# =============================================================================
# payment-verification-service — environment configuration
# Copy this file to `.env` and fill in real values.
# =============================================================================

# ---- Service ----
PAYMENT_VERIFICATION_PORT=5004
CORS_ORIGIN=*

# ---- Database (Supabase PostgreSQL) ----
# Same Supabase project as admin-service / order-service / tracking-service.
DB_HOST=aws-1-ap-southeast-1.pooler.supabase.com
DB_PORT=5432
DB_USER=postgres.aygbtulwwpwsujiomgtm
DB_PASS=YOUR-DATABASE-PASSWORD
DB_NAME=postgres

# ---- Uploads ----
# Must point at the SAME directory admin-service writes payment-evidence
# screenshots into (its UPLOADS_DIR) — this service only reads from it.
# Production default matches admin-service's default.
UPLOADS_DIR=/var/www/backend/uploads

# ---- Expected payee details (what OCR checks screenshots against) ----
# These must match the real bank details customers are told to pay into
# (see admin-service's payment-capture email template) — NOT arbitrary values.
PAYMENT_PAYEE_NAME=HSA INTERPAY UK
PAYMENT_SORT_CODE=60-95-61
PAYMENT_ACCOUNT_NUMBER=21327124

# Minimum approval-probability threshold (0-1). Raise to be stricter.
PAYMENT_DECISION_THRESHOLD=0.80
